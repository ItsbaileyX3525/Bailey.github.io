var turn = "X";

// Add event listeners to each cell
for (var i = 0; i < cells.length; i++) {
cells[i].addEventListener("click", function() {
// Get the id of the clicked cell
var id = this.id;
// Get the index of the cell in the board array
var index = parseInt(id.charAt(1)) - 1;
// Check if the cell is empty and it is a valid move
if (board[index] == "" && checkWinner() == false) {
// Update the cell value with X or O
this.value = turn;
// Update the board array with X or O
board[index] = turn;
// Check if there is a winner or a draw
if (checkWinner() == true) {
// Display an alert message with the winner
alert(turn + " wins!");
} else if (checkDraw() == true) {
// Display an alert message with a draw
alert("It's a draw!");
} else {
// Toggle the turn variable between X and O
turn = turn == "X" ? "O" : "X";
}
}
